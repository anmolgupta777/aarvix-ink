    <a href="https://wa.me/917897505392" 
       style="
       display:inline-block;
       background:#25D366;
       color:#fff;
       padding:12px 25px;
       border-radius:8px;
       text-decoration:none;
       font-size:18px;
       margin-top:10px;
       ">
       Send Payment Screenshot
    </a>

</section>
