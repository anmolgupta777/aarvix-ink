<!-- Appointment Booking Section -->
<section style="background:#000; color:#fff; padding:40px; text-align:center;">
    
    <h2 style="font-size:28px; margin-bottom:20px;">
        Book Appointment
    </h2>

    <p style="font-size:18px; margin-bottom:20px;">
        To confirm your tattoo appointment, 
        pay ₹500 advance using the QR below.
    </p>

    <img src="qr-payment.jpg" 
